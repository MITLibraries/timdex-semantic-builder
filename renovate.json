{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>MITLibraries/renovate-config"
  ],
  "constraintsFiltering": "strict",
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackageNames": [
        "python"
      ],
      "allowedVersions": "<3.15"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "public.ecr.aws/lambda/python"
      ],
      "allowedVersions": "<3.15"
    }
  ]
}
