{
  "$schema": "https://renovatebot.com",
  "extends": [
    "local>MITLibraries/renovate-config"
  ],
  "constraintsFiltering": "strict",
  "lockFileMaintenance": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchManagers": [
        "pep621"
      ],
      "rangeStrategy": "pin"
    },
    {
      "matchPackageNames": [
        "python"
      ],
      "allowedVersions": "<3.15"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "public.ecr.aws/lambda/python"
      ],
      "allowedVersions": "<3.15"
    }
  ]
}
